{
  "uid": "node-exporter",
  "title": "Node Exporter - System Metrics",
  "tags": ["infrastructure", "node-exporter"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m]))) * 100",
        "legendFormat": "CPU Usage"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory Usage"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Disk Usage %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - (node_filesystem_avail_bytes{fstype!~'tmpfs|fuse.lxcfs'} / node_filesystem_size_bytes{fstype!~'tmpfs|fuse.lxcfs'})) * 100",
        "legendFormat": "{{mountpoint}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_receive_bytes_total{device!~'lo|docker.*|veth.*'}[5m])",
          "legendFormat": "Received {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_transmit_bytes_total{device!~'lo|docker.*|veth.*'}[5m])",
          "legendFormat": "Transmitted {{device}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 5,
      "title": "System Load Average",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"datasource": "Prometheus", "expr": "node_load1", "legendFormat": "1m"},
        {"datasource": "Prometheus", "expr": "node_load5", "legendFormat": "5m"},
        {"datasource": "Prometheus", "expr": "node_load15", "legendFormat": "15m"}
      ]
    },
    {
      "id": 6,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "Read {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "Write {{device}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ],
  "schemaVersion": 38
}
