# Rename this file to .env and update values before starting the monitoring stack.

# The application server host that Prometheus Blackbox exporter will probe.
APP_HOST=127.0.0.1

# Slack incoming webhook for Alertmanager notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# GitHub Actions repository and token used by the CI/CD metrics exporter.
GITHUB_REPOSITORY=owner/repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Grafana admin credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
